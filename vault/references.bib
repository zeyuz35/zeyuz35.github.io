@article{su_time-varying_2017,
	title = {On time-varying factor models: Estimation and testing},
	volume = {198},
	issn = {0304-4076},
	url = {https://www.sciencedirect.com/science/article/pii/S0304407617300143},
	doi = {10.1016/j.jeconom.2016.12.004},
	shorttitle = {On time-varying factor models},
	abstract = {Conventional factor models assume that factor loadings are fixed over a long horizon of time, which appears overly restrictive and unrealistic in applications. In this paper, we introduce a time-varying factor model where factor loadings are allowed to change smoothly over time. We propose a local version of the principal component method to estimate the latent factors and time-varying factor loadings simultaneously. We establish the limiting distributions and uniform convergence of the estimated factors and factor loadings in the standard large N and large T framework. We also propose a {BIC}-type information criterion to determine the number of factors, which can be used in models with either time-varying or time-invariant factor models. Based on the comparison between the estimates of the common components under the null hypothesis of no structural changes and those under the alternative, we propose a consistent test for structural changes in factor loadings. We establish the null distribution, the asymptotic local power property, and the consistency of our test. Simulations are conducted to evaluate both our nonparametric estimates and test statistic. We also apply our test to investigate Stock and Watson’s (2009) U.S. macroeconomic data set and find strong evidence of structural changes in the factor loadings.},
	pages = {84--101},
	number = {1},
	journaltitle = {Journal of Econometrics},
	shortjournal = {Journal of Econometrics},
	author = {Su, Liangjun and Wang, Xia},
	urldate = {2021-07-13},
	date = {2017-05-01},
	langid = {english},
	keywords = {Factor model, Structural change, Information criterion, Time-varying parameter, Local principal component, Local smoothing, Test},
	file = {ScienceDirect Full Text PDF:/Users/zyzho4/Zotero/storage/STRHS8UG/Su and Wang - 2017 - On time-varying factor models Estimation and test.pdf:application/pdf;Su and Wang - 2017 - On time-varying factor models Estimation and test.pdf:/Users/zyzho4/Zotero/storage/CYYAFMJ6/Su and Wang - 2017 - On time-varying factor models Estimation and test.pdf:application/pdf},
}

@article{corradi_testing_2014,
	title = {Testing for structural stability of factor augmented forecasting models},
	volume = {182},
	issn = {0304-4076},
	url = {https://www.sciencedirect.com/science/article/pii/S0304407614000700},
	doi = {10.1016/j.jeconom.2014.04.011},
	series = {Causality, Prediction, and Specification Analysis: Recent Advances and Future Directions},
	abstract = {Mild factor loading instability, particularly if sufficiently independent across the different constituent variables, does not affect the estimation of the number of factors, nor subsequent estimation of the factors themselves (see e.g.  Stock and Watson (2009)). This result does not hold in the presence of large common breaks in the factor loadings, however. In this case, information criteria overestimate the number of breaks. Additionally, estimated factors are no longer consistent estimators of “true” factors. Hence, various recent research papers in the diffusion index literature focus on testing the constancy of factor loadings. However, forecast failure of factor augmented models can be due to either factor loading instability, regression coefficient instability, or both. To address this issue, we develop a test for the joint hypothesis of structural stability of both factor loadings and factor augmented forecasting model regression coefficients. Our proposed test statistic has a chi-squared limiting distribution, and we are able to establish the first order validity of (block) bootstrap critical values. Empirical evidence is also presented for 11 {US} macroeconomic indicators.},
	pages = {100--118},
	number = {1},
	journaltitle = {Journal of Econometrics},
	shortjournal = {Journal of Econometrics},
	author = {Corradi, Valentina and Swanson, Norman R.},
	urldate = {2021-07-13},
	date = {2014-09-01},
	langid = {english},
	keywords = {Diffusion index, Factor loading stability, Forecast failure, Forecast stability, Regression coefficients stability},
	file = {ScienceDirect Full Text PDF:/Users/zyzho4/Zotero/storage/DTX8DQ6Q/Corradi and Swanson - 2014 - Testing for structural stability of factor augment.pdf:application/pdf},
}

@article{motta_locally_2011,
