  file = {/home/zeyuz/Zotero/storage/H8Q3C6JI/Carriero et al. - 2016 - Common Drifting Volatility in Large Bayesian VARs.pdf;/home/zeyuz/Zotero/storage/W63BPLEF/07350015.2015.html}
