	doi = {10.2139/ssrn.2665111},
	keywords = {Break-point detection, Fixed T asymptotics, Method of moments, Unobserved heterpgeneity},
	file = {Full Text PDF:/Users/zyzho4/Zotero/storage/LKUVSBJL/Zhu et al. - 2015 - Testing for a Structural Break in Dynamic Panel Da.pdf:application/pdf},
}

