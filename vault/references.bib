	date = {2006-01-01},
	langid = {english},
	doi = {10.1016/S1574-0706(05)01010-4},
	keywords = {Bayesian model averaging, dynamic factor models, empirical Bayes forecasts, forecast combining, principal components analysis, shrinkage forecasts},
}

