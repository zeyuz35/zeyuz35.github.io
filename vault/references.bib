	file = {ScienceDirect Full Text PDF:/Users/zyzho4/Zotero/storage/IN3SQYJY/Corradi and Swanson - 2014 - Testing for structural stability of factor augment.pdf:application/pdf},
}

@report{ramey_government_2014,
