	pages = {241--258},
	file = {ScienceDirect Snapshot:/Users/zyzho4/Zotero/storage/UMVPQDEH/S0165188915300087.html:text/html;ScienceDirect Full Text PDF:/Users/zyzho4/Zotero/storage/2RDSDH68/Lütkepohl and Milunovich - 2016 - Testing for identification in SVAR-GARCH models.pdf:application/pdf},
}

