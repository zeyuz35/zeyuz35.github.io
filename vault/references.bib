	langid = {english},
	keywords = {Principal components, Adaptive {LASSO}, Conditional sparse, Cross-sectional correlation, Heteroskedasticity, High dimensionality, Penalized maximum likelihood, {SCAD}, Thresholding, Unknown factors},
}

