	keywords = {Principal components, C32, C38, C55, E17, E37, E47, Factor-augmented vector autoregressions, Large-model forecasting, Nowcasting, State-space models, Structural shocks, Structural vector autoregressions},
	file = {ScienceDirect Snapshot:/Users/zyzho4/Zotero/storage/ZQ2CNBMD/S1574004816300027.html:text/html;Stock and Watson - 2016 - Chapter 8 - Dynamic Factor Models, Factor-Augmente.pdf:/Users/zyzho4/Zotero/storage/76V4ULJW/Stock and Watson - 2016 - Chapter 8 - Dynamic Factor Models, Factor-Augmente.pdf:application/pdf},
