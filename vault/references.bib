	pages = {1175--1189},
	file = {Submitted Version:/Users/zyzho4/Zotero/storage/M5P4X7RW/Hansen - 2007 - Least Squares Model Averaging.pdf:application/pdf},
}

@article{hansen_averaging_2009,
