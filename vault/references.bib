	langid = {english},
	keywords = {Factor model, High-dimensional time series, Non-stationary process, Threshold variable},
	file = {ScienceDirect Full Text PDF:/Users/zyzho4/Zotero/storage/65TST6MG/Liu and Chen - 2020 - Threshold factor models for high-dimensional time .pdf:application/pdf},
}

