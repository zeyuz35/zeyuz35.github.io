	doi = {10.1016/j.jeconom.2009.10.020},
	series = {Nonlinear and Nonparametric Methods in Econometrics},
	abstract = {This paper establishes the consistency of the estimated common break point in panel data. Consistency is obtainable even when a regime contains a single observation, making it possible to quickly identify the onset of a new regime. We also propose a new framework for developing the limiting distribution for the estimated break point, and show how to construct confidence intervals. The least squares method is used for estimating breaks in means and the quasi-maximum likelihood ({QML}) method is used to estimate breaks in means and in variances. {QML} is shown to be more efficient than the least squares even if there is no change in the variances.},
	pages = {78--92},
