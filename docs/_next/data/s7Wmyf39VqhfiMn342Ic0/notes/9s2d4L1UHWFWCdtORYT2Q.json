{"pageProps":{"note":{"id":"9s2d4L1UHWFWCdtORYT2Q","title":"BEX6510 Notes","vault":{"fsPath":"vault"},"type":"note","desc":"","links":[],"anchors":{"resources-for-getting-paths-working":{"type":"header","text":"Resources for getting paths working","value":"resources-for-getting-paths-working","line":11,"column":0},"matrix-algebra":{"type":"header","text":"Matrix Algebra","value":"matrix-algebra","line":23,"column":0},"linear-models":{"type":"header","text":"Linear Models","value":"linear-models","line":27,"column":0},"fwl-theorem":{"type":"header","text":"FWL Theorem","value":"fwl-theorem","line":41,"column":0},"statistical-properties-of-ols":{"type":"header","text":"Statistical Properties of OLS","value":"statistical-properties-of-ols","line":45,"column":0},"inference":{"type":"header","text":"Inference","value":"inference","line":53,"column":0},"chow-test":{"type":"header","text":"Chow test","value":"chow-test","line":73,"column":0},"likelihood":{"type":"header","text":"Likelihood","value":"likelihood","line":91,"column":0},"notation":{"type":"header","text":"Notation","value":"notation","line":103,"column":0},"conditions":{"type":"header","text":"Conditions","value":"conditions","line":115,"column":0},"statistical-properties-of-mle":{"type":"header","text":"Statistical Properties of MLE","value":"statistical-properties-of-mle","line":133,"column":0},"ols-mle":{"type":"header","text":"OLS MLE","value":"ols-mle","line":145,"column":0},"asymptotic-properties":{"type":"header","text":"Asymptotic Properties","value":"asymptotic-properties","line":151,"column":0},"inference-1":{"type":"header","text":"Inference","value":"inference-1","line":159,"column":0},"wald-test":{"type":"header","text":"Wald Test","value":"wald-test","line":165,"column":0},"lmgradient-test":{"type":"header","text":"LM/Gradient Test","value":"lmgradient-test","line":171,"column":0},"likelihood-ratio-criterion-differnce-test":{"type":"header","text":"Likelihood Ratio (criterion differnce) test","value":"likelihood-ratio-criterion-differnce-test","line":177,"column":0},"stochastic-order":{"type":"header","text":"Stochastic Order","value":"stochastic-order","line":185,"column":0},"generalised-method-of-moments":{"type":"header","text":"Generalised Method of Moments","value":"generalised-method-of-moments","line":189,"column":0},"asymptotics":{"type":"header","text":"Asymptotics","value":"asymptotics","line":207,"column":0},"weighting-matrix":{"type":"header","text":"Weighting matrix","value":"weighting-matrix","line":221,"column":0},"ols":{"type":"header","text":"OLS","value":"ols","line":231,"column":0},"iv-regression":{"type":"header","text":"IV Regression","value":"iv-regression","line":237,"column":0},"mle":{"type":"header","text":"MLE","value":"mle","line":245,"column":0},"inference-2":{"type":"header","text":"Inference","value":"inference-2","line":250,"column":0},"j-test-test-oof-overidentifying-restrictions":{"type":"header","text":"J Test (test oof overidentifying restrictions)","value":"j-test-test-oof-overidentifying-restrictions","line":252,"column":0},"notation-1":{"type":"header","text":"Notation","value":"notation-1","line":257,"column":0},"wald-test-1":{"type":"header","text":"Wald Test","value":"wald-test-1","line":262,"column":0},"lmgradient-test-1":{"type":"header","text":"LM/Gradient Test","value":"lmgradient-test-1","line":268,"column":0},"criterion-difference-test":{"type":"header","text":"Criterion Difference Test","value":"criterion-difference-test","line":272,"column":0},"min-chi-squared-test":{"type":"header","text":"Min Chi Squared Test","value":"min-chi-squared-test","line":279,"column":0},"auxiliary-moment-tests":{"type":"header","text":"Auxiliary Moment Tests","value":"auxiliary-moment-tests","line":284,"column":0},"conditional-moment-test":{"type":"header","text":"Conditional Moment Test","value":"conditional-moment-test","line":294,"column":0},"extremum-estimators":{"type":"header","text":"Extremum Estimators","value":"extremum-estimators","line":295,"column":0},"m-estimators":{"type":"header","text":"M Estimators","value":"m-estimators","line":297,"column":0},"censoring-and-truncation":{"type":"header","text":"Censoring and Truncation","value":"censoring-and-truncation","line":300,"column":0},"truncated":{"type":"header","text":"Truncated","value":"truncated","line":304,"column":0},"censored":{"type":"header","text":"Censored","value":"censored","line":308,"column":0},"generalised-linear-models-glms":{"type":"header","text":"Generalised Linear Models (GLMs)","value":"generalised-linear-models-glms","line":314,"column":0},"deviance":{"type":"header","text":"Deviance","value":"deviance","line":338,"column":0}},"fname":"BEX6510","updated":1637716395227,"created":1636775361328,"parent":"PhD","children":[],"data":{},"contentHash":"765127bed8764f37633391d0cbe498e4","custom":{"geometry":"margin=2cm","bibliography":["references.bib"]}},"body":"<h1 id=\"bex6510-notes\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#bex6510-notes\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>BEX6510 Notes</h1>\n<h2 id=\"resources-for-getting-paths-working\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#resources-for-getting-paths-working\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Resources for getting paths working</h2>\n<p><a href=\"https://www.randigriffin.com/2017/04/25/how-to-knit-for-mysite.html\">https://www.randigriffin.com/2017/04/25/how-to-knit-for-mysite.html</a></p>\n<p><a href=\"https://nb.balaji.blog/posts/pandoc-extract-images/\">https://nb.balaji.blog/posts/pandoc-extract-images/</a></p>\n<p><a href=\"https://stackoverflow.com/questions/41604263/how-do-i-display-local-image-in-markdown\">https://stackoverflow.com/questions/41604263/how-do-i-display-local-image-in-markdown</a></p>\n<p><a href=\"https://gist.github.com/cben/46d9536baacb7c5d196c/\">https://gist.github.com/cben/46d9536baacb7c5d196c/</a></p>\n<h2 id=\"matrix-algebra\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#matrix-algebra\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Matrix Algebra</h2>\n<h2 id=\"linear-models\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#linear-models\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Linear Models</h2>\n<p>Notation</p>\n<p><img src=\"./assets/images/2021-11-16-11-50-24.png\"></p>\n<p>Assumptions/regularity conditions</p>\n<p><img src=\"./assets/images/2021-11-16-11-49-32.png\"></p>\n<p>Useful matrix algebra identity </p>\n<p><img src=\"./assets/images/2021-11-16-11-52-12.png\">{max-width=80%}</p>\n<h3 id=\"fwl-theorem\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#fwl-theorem\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>FWL Theorem</h3>\n<p><img src=\"./assets/images/2021-11-16-11-53-34.png\"></p>\n<h3 id=\"statistical-properties-of-ols\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#statistical-properties-of-ols\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Statistical Properties of OLS</h3>\n<p><img src=\"./assets/images/2021-11-16-11-54-19.png\"></p>\n<p>Proof of variance of residuals</p>\n<p><img src=\"./assets/images/2021-11-16-11-55-20.png\"></p>\n<h3 id=\"inference\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#inference\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Inference</h3>\n<p>The very basic case</p>\n<p><img src=\"./assets/images/2021-11-16-11-57-55.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-11-58-12.png\"></p>\n<p>More generally</p>\n<p><img src=\"./assets/images/2021-11-16-11-59-07.png\"></p>\n<p>Restricted Least Squares (Lagrange Approach)</p>\n<p><img src=\"./assets/images/2021-11-16-12-00-06.png\"></p>\n<p>Note the choice of choosing the lagrange multiplier to has a constant in front to simplify things!</p>\n<p><img src=\"./assets/images/2021-11-16-12-00-24.png\"></p>\n<h3 id=\"chow-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#chow-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Chow test</h3>\n<p>Normal derivation</p>\n<p><img src=\"./assets/images/2021-11-16-12-01-39.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-03-37.png\"></p>\n<p>Alternative derivation when one of the sub samples has less observations than regressors:</p>\n<p><img src=\"./assets/images/2021-11-16-12-04-18.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-04-50.png\"></p>\n<p>This is an F test with (T - T2 - k) = (T1 - k) dof and T2 indicator variables (restrictions).</p>\n<p><img src=\"./assets/images/2021-11-16-12-05-05.png\"></p>\n<h2 id=\"likelihood\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#likelihood\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Likelihood</h2>\n<p>KL divergence. Note that the relative orders of the thetas are reversed in the fraction. </p>\n<p><img src=\"./assets/images/2021-11-16-12-08-00.png\"></p>\n<p>This proof is straightforward, but tedious. Focus on a case of n = 2. Just expand out the multiplication, etc.</p>\n<p><img src=\"./assets/images/2021-11-16-12-09-05.png\"></p>\n<p>Remember that log(x) is concave, and -log(x) is convex.</p>\n<h3 id=\"notation\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#notation\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Notation</h3>\n<p>The support function is the loglikelihood</p>\n<p>The score is the 1st derivative of the loglikelihood</p>\n<p>The hessian is the 2nd derivative of the loglikelihood</p>\n<p>The fisher information is the expected value of the outer product of the score</p>\n<p>Under certain conditions, the fisher information is also negative expected value of the hessian</p>\n<h3 id=\"conditions\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#conditions\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Conditions</h3>\n<p>MLE estimator itself <em>exists</em>.</p>\n<p>In practical terms, need to check that:</p>\n<ol>\n<li>loglik is continuous and differentiable wrt theta</li>\n<li>loglik is bounded (finite)</li>\n<li>limits of loglik, and check that this crosses over 0 (implies a turning point, and hence existence)</li>\n</ol>\n<p>Alternatively, use the second derivative directly:</p>\n<p><img src=\"./assets/images/2021-11-16-12-11-09.png\"></p>\n<p>If the parameter space is convex, and loglik is concave (negative 2nd derivative), then the MLE <em>exists</em> and is <em>unique</em> (note that uniqueness impliex existence).</p>\n<p><img src=\"./assets/images/2021-11-16-12-13-54.png\"></p>\n<h3 id=\"statistical-properties-of-mle\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#statistical-properties-of-mle\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Statistical Properties of MLE</h3>\n<p><img src=\"./assets/images/2021-11-16-12-15-34.png\"></p>\n<p>Easy way to check that some <em>unbiased</em> estimator reaches the CRLB. </p>\n<p><img src=\"./assets/images/2021-11-16-12-16-39.png\"></p>\n<p>Practically, in the case of MLE, K(theta) can actually be <em>any</em> arbitrary function of theta, as noted by Casella and Berger, pg 364.</p>\n<p><img src=\"./assets/images/2021-11-16-12-18-14.png\"></p>\n<h4 id=\"ols-mle\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#ols-mle\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>OLS MLE</h4>\n<p><img src=\"./assets/images/2021-11-16-12-18-59.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-19-15.png\"></p>\n<h3 id=\"asymptotic-properties\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#asymptotic-properties\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Asymptotic Properties</h3>\n<p>General distribution of MLE:</p>\n<p><img src=\"./assets/images/2021-11-16-12-20-20.png\"></p>\n<p>Note that the information matrix relies on <em>true</em> theta0, so instead use i(theta hat) as a consistent estimator for it.</p>\n<h3 id=\"inference-1\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#inference-1\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Inference</h3>\n<p>Restrictions are denoted</p>\n<p><img src=\"./assets/images/2021-11-16-12-21-52.png\"></p>\n<h4 id=\"wald-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#wald-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Wald Test</h4>\n<p><img src=\"./assets/images/2021-11-16-12-22-06.png\"></p>\n<p>Proof: 1st order Taylor Expand h(theta hat) about true theta 0</p>\n<h4 id=\"lmgradient-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#lmgradient-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>LM/Gradient Test</h4>\n<p><img src=\"./assets/images/2021-11-16-12-23-11.png\"></p>\n<p>The proof in the notes has typos. </p>\n<h4 id=\"likelihood-ratio-criterion-differnce-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#likelihood-ratio-criterion-differnce-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Likelihood Ratio (criterion differnce) test</h4>\n<p>The easiest one!</p>\n<p><img src=\"./assets/images/2021-11-16-12-23-43.png\"></p>\n<p>Proof is harder, requires 2nd order Taylor Series expansion. </p>\n<h2 id=\"stochastic-order\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#stochastic-order\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Stochastic Order</h2>\n<h2 id=\"generalised-method-of-moments\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#generalised-method-of-moments\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Generalised Method of Moments</h2>\n<p>Note that Method of Moments is too easy and skipped (not too exciting).</p>\n<p>There are p parameters, and k moment conditions</p>\n<p>The true moment conditions are denoted by h, s.t. E(h) = 0</p>\n<p>The sample moment conditions are denoted by m, whose sample (empirical) means correspond to E(h)</p>\n<p><img src=\"./assets/images/2021-11-16-12-45-57.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-46-15.png\"></p>\n<p>GMM is identified if:</p>\n<p><img src=\"./assets/images/2021-11-16-12-48-01.png\"></p>\n<h3 id=\"asymptotics\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#asymptotics\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Asymptotics</h3>\n<p><img src=\"./assets/images/2021-11-16-12-48-44.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-48-53.png\"></p>\n<p>The proof is a straightforward, by tedious Taylor Series expansion about m(theta hat)</p>\n<p>Relative Efficiency</p>\n<p><img src=\"./assets/images/2021-11-16-12-49-43.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-49-57.png\"></p>\n<h3 id=\"weighting-matrix\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#weighting-matrix\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Weighting matrix</h3>\n<p>A an efficient weighting matrix needs to chosen up to a proportionality:</p>\n<p><img src=\"./assets/images/2021-11-16-12-50-40.png\"></p>\n<p>In practice, is it easier to directly work out the variance of the moment conditions and get the standard efficient weighting matrix.</p>\n<p>However, the previous result is useful, as this allows us to be sloppy with constants (e.g. missing Ts).</p>\n<h4 id=\"ols\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#ols\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>OLS</h4>\n<p>Worked example</p>\n<p><img src=\"./assets/images/2021-11-16-12-52-19.png\"></p>\n<h4 id=\"iv-regression\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#iv-regression\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>IV Regression</h4>\n<p>Worked Example. Note that sometimes Don is sloppy and specifies different T proportionalities.</p>\n<p><img src=\"./assets/images/2021-11-16-12-53-28.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-12-53-44.png\"></p>\n<h4 id=\"mle\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#mle\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>MLE</h4>\n<p>Worked Example</p>\n<h3 id=\"inference-2\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#inference-2\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Inference</h3>\n<h4 id=\"j-test-test-oof-overidentifying-restrictions\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#j-test-test-oof-overidentifying-restrictions\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>J Test (test oof overidentifying restrictions)</h4>\n<p><img src=\"./assets/images/2021-11-16-14-47-51.png\"></p>\n<h4 id=\"notation-1\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#notation-1\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Notation</h4>\n<p><img src=\"./assets/images/2021-11-16-14-48-21.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-14-48-33.png\"></p>\n<h4 id=\"wald-test-1\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#wald-test-1\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Wald Test</h4>\n<p><img src=\"./assets/images/2021-11-16-14-48-48.png\"></p>\n<p>This has a typo, the variance should not be inverted.</p>\n<h4 id=\"lmgradient-test-1\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#lmgradient-test-1\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>LM/Gradient Test</h4>\n<p><img src=\"./assets/images/2021-11-16-14-49-25.png\"></p>\n<h4 id=\"criterion-difference-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#criterion-difference-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Criterion Difference Test</h4>\n<p>Again, the easiest one!</p>\n<p><img src=\"./assets/images/2021-11-16-14-49-45.png\"></p>\n<h4 id=\"min-chi-squared-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#min-chi-squared-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Min Chi Squared Test</h4>\n<p><img src=\"./assets/images/2021-11-16-14-50-29.png\"></p>\n<p>It can be shown that Min Chi Square and Criterion Dfference test are the same (unsurprisingly)</p>\n<h4 id=\"auxiliary-moment-tests\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#auxiliary-moment-tests\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Auxiliary Moment Tests</h4>\n<p><img src=\"./assets/images/2021-11-16-14-51-26.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-14-51-44.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-14-51-58.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-14-52-13.png\"></p>\n<h4 id=\"conditional-moment-test\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#conditional-moment-test\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Conditional Moment Test</h4>\n<h2 id=\"extremum-estimators\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#extremum-estimators\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Extremum Estimators</h2>\n<h3 id=\"m-estimators\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#m-estimators\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>M Estimators</h3>\n<p>Extremum estimators which minimize a sample average criteron are called M estimators.</p>\n<h2 id=\"censoring-and-truncation\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#censoring-and-truncation\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Censoring and Truncation</h2>\n<h3 id=\"truncated\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#truncated\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Truncated</h3>\n<p>A <em>truncated</em> distribution is where any observations exceeding some threshold are not observed at all.</p>\n<h3 id=\"censored\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#censored\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Censored</h3>\n<p>A <em>censored</em> distribution is where any observations exceeding some threshold are simply recorded as that threshold, but its actual value is unknown (censored).</p>\n<h2 id=\"generalised-linear-models-glms\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#generalised-linear-models-glms\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Generalised Linear Models (GLMs)</h2>\n<p><img src=\"./assets/images/2021-11-16-14-40-06.png\"></p>\n<p>Common exponential family:</p>\n<p><img src=\"./assets/images/2021-11-16-14-40-21.png\"></p>\n<p>A more general definition of this is given:</p>\n<p><img src=\"./assets/images/2021-11-16-14-41-23.png\"></p>\n<p>Take special note of the cumulant generating function for the sufficient statistic:</p>\n<p><img src=\"./assets/images/2021-11-16-14-41-39.png\"></p>\n<p>This is actually also given in Don's notes, though not so clearly</p>\n<p><img src=\"./assets/images/2021-11-16-14-42-54.png\"></p>\n<p>GLMs are estimated by MLE, with the following asymptotic properties</p>\n<p><img src=\"./assets/images/2021-11-16-14-45-00.png\"></p>\n<h3 id=\"deviance\"><a aria-hidden=\"true\" class=\"anchor-heading\" href=\"#deviance\"><svg aria-hidden=\"true\" viewBox=\"0 0 16 16\"><use xlink:href=\"#svg-link\"></use></svg></a>Deviance</h3>\n<p><img src=\"./assets/images/2021-11-16-14-45-50.png\"></p>\n<p><img src=\"./assets/images/2021-11-16-14-46-13.png\"></p>\n<p>Pearson Residual</p>\n<p><img src=\"./assets/images/2021-11-16-14-46-36.png\"></p>","noteIndex":{"id":"PhD","title":"PhD Homepage","vault":{"fsPath":"vault"},"type":"note","desc":"","links":[{"type":"wiki","from":{"fname":"root","id":"PhD","vaultName":"vault"},"value":"roadmap","alias":"roadmap","position":{"start":{"line":12,"column":1,"offset":451},"end":{"line":12,"column":12,"offset":462},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"roadmap"}},{"type":"wiki","from":{"fname":"root","id":"PhD","vaultName":"vault"},"value":"Meeting","alias":"Meeting","position":{"start":{"line":14,"column":1,"offset":464},"end":{"line":14,"column":12,"offset":475},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"Meeting"}},{"type":"wiki","from":{"fname":"root","id":"PhD","vaultName":"vault"},"value":"TODO","alias":"TODO","position":{"start":{"line":16,"column":1,"offset":477},"end":{"line":16,"column":9,"offset":485},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"TODO"}}],"anchors":{"quick-links":{"type":"header","text":"Quick Links","value":"quick-links","line":17,"column":0}},"fname":"root","updated":1637563604861,"created":1595961348801,"parent":null,"children":["t58wEmhAtf1GlHmO","Wnsnl9Ff8hLGapBoL37BK","CQTUwoXQNcd0Y7la7IaAn","9s2d4L1UHWFWCdtORYT2Q","AiXOWFsdvi3BPZxcUMjI